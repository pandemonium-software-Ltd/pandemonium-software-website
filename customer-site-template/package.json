    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "wrangler": "^4.81.0"
