// Cloudflare Workers config — Next.js SSR via @opennextjs/cloudflare.
//
// Build: `opennextjs-cloudflare build` produces .open-next/ with:
//   - worker.js: the SSR entrypoint
//   - assets/: static files (CSS, JS, images, _headers)
//
// The `main` field points to the worker script. `assets.directory`
// points to the static asset directory. Both are outputs of the
// OpenNext build — don't create them manually.
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "pandemonium-software-website",
	"main": ".open-next/worker.js",
	"compatibility_date": "2026-04-11",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	// R2 bucket for customer-uploaded brand assets (Hub Step 4).
	// Bucket lives at the account level; Worker accesses it via the
	// ASSETS_BUCKET binding (env.ASSETS_BUCKET in Worker code, surfaced
	// via @opennextjs/cloudflare's getCloudflareContext().env). Public
	// dev URL configured separately (see R2_PUBLIC_URL_BASE env var).
	"r2_buckets": [
		{
			"binding": "ASSETS_BUCKET",
			"bucket_name": "moduforge-customer-assets"
		}
	],
	// GitHub repo for the customer-site-build + customer-site-promote
	// workflows. The marketing-site Worker dispatches these from:
	//   - /api/admin/change-request (operator approves a change → rebuild)
	//   - /api/admin/review-edit (operator approves a Hub Step 5 edit
	//     → build to deploy)
	//   - /account/[token]/approve-change/[crId] (customer approves a
	//     preview → promote)
	// GITHUB_TOKEN is set via `wrangler secret put GITHUB_TOKEN`.
	// Same trio also lives in wrangler-ops.jsonc so the ops worker
	// can dispatch independently.
	"vars": {
		"GITHUB_OWNER": "pandemonium-software-Ltd",
		"GITHUB_REPO": "pandemonium-software-website"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "pandemonium_analytics",
			"database_name": "pandemonium-analytics",
			"database_id": "c996208f-8f7f-4040-92b4-7a65e5e364ae",
			"remote": true
		}
	],
	// --- Staging environment (master-plan 0.1) ---------------------------
	// A SEPARATE Worker with isolated bindings. Deploy with:
	//   npm run deploy:staging
	// It does NOT affect production — wrangler only uses this block when
	// `--env staging` is passed. Lives at:
	//   pandemonium-software-website-staging.<your-subdomain>.workers.dev
	//
	// TWO PLACEHOLDERS TO FILL IN (create the resources first):
	//   1. Staging R2 bucket — create it, then it matches "bucket_name" below:
	//        npx wrangler r2 bucket create moduforge-customer-assets-staging
	//   2. Staging D1 — create it and paste the returned id into "database_id":
	//        npx wrangler d1 create pandemonium-analytics-staging
	//
	// Then set staging secrets (test/staging values, NOT production):
	//   npx wrangler secret put NOTION_API_KEY --env staging
	//   npx wrangler secret put STRIPE_SECRET_KEY --env staging      (sk_test_…)
	//   npx wrangler secret put STRIPE_WEBHOOK_SECRET --env staging   (test)
	//   npx wrangler secret put RESEND_API_KEY --env staging
	//   npx wrangler secret put ANTHROPIC_API_KEY --env staging
	//   npx wrangler secret put SESSION_SECRET --env staging
	"env": {
		"staging": {
			"name": "pandemonium-software-website-staging",
			"vars": {
				"GITHUB_OWNER": "pandemonium-software-Ltd",
				"GITHUB_REPO": "pandemonium-software-website"
			},
			"r2_buckets": [
				{
					"binding": "ASSETS_BUCKET",
					"bucket_name": "moduforge-customer-assets-staging"
				}
			],
			"d1_databases": [
				{
					"binding": "pandemonium_analytics",
					"database_name": "pandemonium-analytics-staging",
					"database_id": "REPLACE_WITH_STAGING_D1_ID",
					"remote": true
				}
			],
			"observability": {
				"enabled": true
			}
		}
	}
}