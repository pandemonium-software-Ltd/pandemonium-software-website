{
  "name": "pandemonium-software-website",
  "version": "0.2.0",
  "private": true,
  "description": "Marketing website and prospect pipeline for Pandemonium Software Ltd.",
  "scripts": {
    "dev": "next dev",
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "build:next": "next build",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "deploy": "npm run build && opennextjs-cloudflare deploy",
    "deploy:ops": "wrangler deploy --config wrangler-ops.jsonc",
    "dev:ops": "wrangler dev --config wrangler-ops.jsonc --test-scheduled",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@hookform/resolvers": "^3.9.1",
    "@notionhq/client": "^2.3.0",
    "@sentry/cloudflare": "^10.53.1",
    "browser-image-compression": "^2.0.2",
    "heic2any": "^0.0.4",
    "next": "^15.5.18",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.55.0",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.81.0"
  }
}
